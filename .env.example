# herdr-ntfysh configuration
#
# Copy this file to the plugin's config directory and edit it:
#
#   cp .env.example "$(herdr plugin config-dir cobanov.herdr-ntfysh)/.env"
#
# Every value can also be supplied as a process environment variable of the
# same name, which overrides the file.

# --- Required -------------------------------------------------------------

# Base URL of your ntfy server, including scheme. For a self-hosted instance
# on your Proxmox box this might be an internal hostname or IP.
HERDR_NTFY_SERVER=https://ntfy.example.com

# Topic to publish to.
HERDR_NTFY_TOPIC=herdr

# --- Authentication (pick at most one) -----------------------------------

# ntfy access token (Bearer auth). Takes precedence over username/password.
#HERDR_NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxx

# HTTP Basic auth.
#HERDR_NTFY_USERNAME=herder
#HERDR_NTFY_PASSWORD=changeme

# --- Self-hosted TLS ------------------------------------------------------

# Skip TLS certificate verification (self-signed cert). Prefer HERDR_NTFY_CA_FILE.
#HERDR_NTFY_TLS_INSECURE=false

# Path to a PEM bundle used to verify the server certificate.
#HERDR_NTFY_CA_FILE=/etc/ssl/certs/my-ntfy-ca.pem

# --- Behavior -------------------------------------------------------------

# Master switch.
#HERDR_NTFY_ENABLED=true

# Comma-separated notification kinds that trigger a push.
# Valid values: done, blocked, working, idle.
#   done    -> herdr's completion (explicit "done", or a working->idle turn)
#   blocked -> agent needs your input
#   working -> agent started working (noisy)
#   idle    -> any entry into idle (noisy)
#HERDR_NTFY_NOTIFY_ON=done,blocked

# Per-status ntfy priority. Accepts 1..5 or min/low/default/high/max.
#HERDR_NTFY_PRIORITY_DONE=default
#HERDR_NTFY_PRIORITY_BLOCKED=high

# Seconds during which an identical status for the same pane is suppressed.
# 0 disables debouncing.
#HERDR_NTFY_DEDUP_WINDOW=10

# HTTP request timeout in seconds.
#HERDR_NTFY_TIMEOUT=10

# --- Presentation ---------------------------------------------------------

# Prefix prepended to every notification title.
#HERDR_NTFY_TITLE_PREFIX=[herdr]

# Extra ntfy tags appended to every notification (comma-separated).
#HERDR_NTFY_TAGS_EXTRA=computer

# Render the message body as Markdown in supported ntfy clients.
#HERDR_NTFY_MARKDOWN=false

# Log the raw event payload and notify decision to the plugin log
# (herdr plugin log list --plugin cobanov.herdr-ntfysh). For debugging only.
#HERDR_NTFY_DEBUG=false

# URL opened when the notification is tapped.
#HERDR_NTFY_CLICK=

# Icon URL shown alongside the notification.
#HERDR_NTFY_ICON=
